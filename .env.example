# AutoScout AI — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Security — protects the deployed app ─────────────────────────────────────
# Generate with: openssl rand -hex 32
# Set this SAME value in both the backend and frontend Railway services
AUTOSCOUT_API_KEY=

# ── AI — Message drafting + listing normalization ────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Facebook Marketplace scraping (via Apify) ────────────────────────────────
# Sign up free at https://apify.com, then enable in config.py SOURCES
APIFY_API_TOKEN=apify_api_...

# ── Vehicle pricing APIs (real transaction data — replaces KBB depreciation model)
# VinAudit: VIN-based market value. 500 free calls. https://vinaudit.com/register
VINAUDIT_API_KEY=

# CarsXE: make/model/year market value (no VIN needed). 100 free calls. https://api.carsxe.com
CARSXE_API_KEY=

# ── SMS alerts for great deals (via Twilio) ──────────────────────────────────
# Sign up at https://twilio.com, enable in config.py NOTIFICATIONS
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+15005550006
TWILIO_TO_NUMBER=+1...
